# Base de datos PostgreSQL (Neon)
# DATABASE_URL → connection string "pooled" (con -pooler en el host)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/DB?sslmode=require"
# DIRECT_URL → connection string directa (sin -pooler), solo para migraciones en build
DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/DB?sslmode=require"

# Panel admin
ADMIN_PASSWORD="change-me"
SESSION_SECRET="use-a-long-random-string-at-least-32-chars"

# Contacto
WHATSAPP_NUMBER=
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/yourstore

# Tienda
NEXT_PUBLIC_STORE_NAME="Flightt.cl"
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Mercado Pago
# MERCADOPAGO_ACCESS_TOKEN=
# NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Imágenes (Vercel Blob en producción)
# BLOB_READ_WRITE_TOKEN=

# Email (Resend)
# RESEND_API_KEY=
# EMAIL_FROM="Store <onboarding@resend.dev>"
# SELLER_EMAIL=

# Cron de recordatorios de retiro
# CRON_SECRET=

# Pie de página (una línea por línea)
# STORE_FOOTER="Shipping via Starken.\nNo returns."
