# Base de datos PostgreSQL (Neon). Usa la URL "pooled" en runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/DB?sslmode=require"

# Panel admin
ADMIN_PASSWORD="change-me"
SESSION_SECRET="use-a-long-random-string-at-least-32-chars"

# Contacto
WHATSAPP_NUMBER=
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/yourstore

# Tienda
NEXT_PUBLIC_STORE_NAME="Flightt.cl"
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Mercado Pago
# MERCADOPAGO_ACCESS_TOKEN=
# NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Imágenes (Vercel Blob en producción)
# BLOB_READ_WRITE_TOKEN=

# Email (Resend)
# RESEND_API_KEY=
# EMAIL_FROM="Store <onboarding@resend.dev>"
# SELLER_EMAIL=

# Cron de recordatorios de retiro
# CRON_SECRET=

# Pie de página (una línea por línea)
# Chilexpress (sandbox: developers.wschilexpress.com → Perfil → Primary key)
# CHILEXPRESS_SUBSCRIPTION_KEY=
# CHILEXPRESS_ENV=sandbox
# Comuna de origen (código 4 letras). Ej. STGO, PROV, NUNO
# CHILEXPRESS_ORIGIN_COUNTY_CODE=STGO
